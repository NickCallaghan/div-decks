{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": "server",
    "declaration": false,
    "sourceMap": false,
    "strict": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/index.ts"]
}
