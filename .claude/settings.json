{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "npx vitest run --reporter=dot 2>&1",
            "timeout": 30,
            "statusMessage": "Running tests before commit..."
          }
        ]
      }
    ]
  }
}
