#!/bin/sh
# Block version bumps without changelog updates.
# If package.json version changes in a commit, CHANGELOG.md must also be staged.

if git diff --cached --name-only | grep -q "^package.json$"; then
  OLD_VERSION=$(git show HEAD:package.json 2>/dev/null | grep '"version"' | head -1 | tr -d ' ",')
  NEW_VERSION=$(git diff --cached -- package.json | grep '^\+.*"version"' | head -1 | tr -d ' ",+')
  if [ -n "$NEW_VERSION" ] && [ "$OLD_VERSION" != "$NEW_VERSION" ]; then
    if ! git diff --cached --name-only | grep -q "^CHANGELOG.md$"; then
      echo ""
      echo "ERROR: package.json version changed but CHANGELOG.md not updated."
      echo "Add a changelog entry before committing the version bump."
      echo ""
      exit 1
    fi
  fi
fi
